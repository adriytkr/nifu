---
import Logo from './Logo.astro';
import SearchArticle from './SearchArticle.astro';
import ThemeToggleButton from './ThemeToggleButton.astro';

import LinkLocale from './LinkLocale.astro';
---

<header class="sticky z-50 transition-transform duration-300 ease-in-out top-0 bg-surface">
  <nav class="max-w-4xl mx-auto p-4 flex justify-between items-center">
    <LinkLocale href="/">
      <Logo/>
    </LinkLocale>
    <div class="flex items-center gap-x-4">
      <LinkLocale href='/articles'>Articles</LinkLocale>
      <SearchArticle/>
      <!-- <LanguagePicker/> -->
      <ThemeToggleButton/>
    </div>
  </nav>
</header>

<style>
header.scroll-down{
  transform:translateY(-100%);
}

header.scroll-up{
  transform:translateY(0);
}
</style>

<script>
  let lastScroll=0;
  const header=document.querySelector('header');

  window.addEventListener('scroll',()=>{
    const currentScroll=window.pageYOffset;

    if(header===null)return;

    if(currentScroll<=0){
      header.classList.remove('scroll-down');
      return;
    }

    if(
      currentScroll>lastScroll&&
      !header.classList.contains('scroll-down')
    ){
      header.classList.remove('scroll-up');
      header.classList.add('scroll-down');
    }else if(
      currentScroll < lastScroll&&
      header.classList.contains('scroll-down')
    ){
      header.classList.remove('scroll-down');
      header.classList.add('scroll-up');
    }

    lastScroll=currentScroll;
  });
</script>

---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'a'>{
  href:string;
}

const {
  href,
  class:className,
  ...props
}=Astro.props;

const { pathname } = Astro.url;

const absoluteHref=Astro.currentLocale==='en'
  ?href
  :`/${Astro.currentLocale}${href}`;

console.log(Astro.currentLocale,pathname);

const isActive=pathname===absoluteHref||pathname===`${absoluteHref}/`;
---

<a 
  href={absoluteHref} 
  class:list={[
    className,
    {'is-active':isActive},
  ]} 
  aria-current={isActive?'page':undefined}
  {...props}
>
  <slot />
</a>

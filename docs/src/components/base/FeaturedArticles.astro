---
import {getCollection} from 'astro:content';

import ArticleList from './ArticleList.astro';
import ArticleCard from './ArticleCard.astro';

const docs=await getCollection('docs');
const featuredArticles=docs.filter(doc=>doc.data.isArticle&&doc.data.isFeatured);
const shuffled=featuredArticles.sort(()=>0.5-Math.random());
const randomArticles=shuffled.slice(0,3);
---

<ArticleList>
  {
    randomArticles.map(article=>(
        <ArticleCard
          title={article.data.title}
          href={'/'+article.id}
          categories={article.data.categories??[]}
          thumbnail={article.data.thumbnail?.src??''}
        >
          <Fragment slot="description">{article.data.description}</Fragment>
        </ArticleCard>
      )
    )
  }
</ArticleList>

{
  "compilerOptions": {
    "paths": {
      "~/*": ["./.vitepress/theme/*"],
      "~~/*": ["./*"],

      "~icons/*": ["./.vitepress/theme/components/icons/*"],

      "~content/*": ["./content/*"],
      "~data/*": ["./.vitepress/theme/data/*"],
    }
  },
  "include":[
    "./.vitepress/**/*.ts",
    "./.vitepress/**/*.vue",
    "**/*.ts",
    "**/*.vue",
    "**/*.md"
  ],
  "exclude": ["./node_modules/"],
  "vueCompilerOptions": {
    "vitePressExtensions": [".md"]
  }
}

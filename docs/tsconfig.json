{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*":["./src/*"],
      "@components/*":["./src/components/*"],
      "@assets/*":["./src/assets/*"],
      // "@fragments/*":["./src/content/_fragments/*"]
    }
  },
}